file1 = input("Enter first audio file name with extension: ")
file2 = input("Enter second audio file name with extension: ")
path1 = "/content/drive/MyDrive/" + file1
path2 = "/content/drive/MyDrive/" + file2
if os.path.exists(path1) and os.path.exists(path2):
    y1, sr1 = librosa.load(path1, sr=None)
    y2, sr2 = librosa.load(path2, sr=None)
    plt.figure(figsize=(14, 8))

    plt.subplot(2, 1, 1)
    librosa.display.waveshow(y1, sr=sr1)
    plt.title("Waveform of " + file1)
    plt.xlabel("Time (seconds)")
    plt.ylabel("Amplitude")
    plt.grid()

    plt.subplot(2, 1, 2)
    librosa.display.waveshow(y2, sr=sr2)
    plt.title("Waveform of " + file2)
    plt.xlabel("Time (seconds)")
    plt.ylabel("Amplitude")
    plt.grid()

    plt.tight_layout()
    plt.show()

else:
    print("One or both files not found in MyDrive.")
    print("Check the file names carefully.")
